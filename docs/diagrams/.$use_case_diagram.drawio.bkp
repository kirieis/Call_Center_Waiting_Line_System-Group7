        <mxCell id="uc13" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=12;fontStyle=1;" value="View circular&lt;br&gt;queue status" vertex="1">
          <mxGeometry height="70" width="210" x="580" y="640" as="geometry" />
        </mxCell>

        <!-- ===== SECONDARY USE CASES (Yellow - include/extend) ===== -->
