        <mxCell id="uc12" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=12;fontStyle=1;" value="Auto sort &amp;&lt;br&gt;load to queue" vertex="1">
          <mxGeometry height="70" width="210" x="360" y="870" as="geometry" />
